<Page x:Class="Tomahawk_Space.Nav.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Tomahawk_Space.Nav"
      mc:Ignorable="d" 
      d:DesignHeight="390" d:DesignWidth="200"
      Title="Home">

    <DockPanel LastChildFill="False">
        <Label DockPanel.Dock="Top" Margin="0,10,0,0" FontSize="16" Content="Главное" FontWeight="Bold"
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Foreground="White"></Label>
        <Border DockPanel.Dock="Top" Height="40" Background="#111" CornerRadius="5" Margin="5,0,5,0">
            <DockPanel LastChildFill="False">
                <CheckBox DockPanel.Dock="Left" Height="30" Width="30" Margin="5,0,0,0" Background="#222"></CheckBox>
                <TextBlock DockPanel.Dock="Right" FontSize="14" Foreground="White" Text="Использовать продвинутый режим" TextWrapping="Wrap" Margin="0,0,10,0"></TextBlock>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Height="120" Margin="5,45,5,0" Background="#111" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBox BorderThickness="0" Background="#222" DockPanel.Dock="Left" Margin="5,0,0,0" 
                             Height="30" Width="60" Name="TextBox_Day" PreviewTextInput="NumberValidationTextBox" VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" MaxLength="2" Foreground="White" FontWeight="Bold">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"></Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Label DockPanel.Dock="Right" VerticalContentAlignment="Center" Width="110"
                           Foreground="White" FontSize="14" Content="День"></Label>
                </DockPanel>
                <DockPanel Grid.Row="1" LastChildFill="False">
                    <TextBox BorderThickness="0" Background="#222" DockPanel.Dock="Left" Margin="5,0,0,0" 
                             Height="30" Width="60" Name="TextBox_Month" PreviewTextInput="NumberValidationTextBox" VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" MaxLength="2" Foreground="White" FontWeight="Bold">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"></Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Label DockPanel.Dock="Right" VerticalContentAlignment="Center" Width="110"
                            Foreground="White" FontSize="14" Content="Месяц"></Label>
                </DockPanel>
                <DockPanel Grid.Row="2" LastChildFill="False">
                    <TextBox BorderThickness="0" Background="#222" DockPanel.Dock="Left" Margin="5,0,0,0" 
                             Height="30" Width="60" Name="TextBox_Year" PreviewTextInput="NumberValidationTextBox" VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" MaxLength="4" Foreground="White" FontWeight="Bold">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"></Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Label DockPanel.Dock="Right" VerticalContentAlignment="Center" Width="110"
                            Foreground="White" FontSize="14" Content="Год"></Label>
                </DockPanel>
            </Grid>
        </Border>

        <Button DockPanel.Dock="Bottom" Height="40" Style="{StaticResource RoundedButton}" FontSize="14" Foreground="White" Content="Загрузить" Margin="5,0,5,5"></Button>
    </DockPanel>
</Page>
