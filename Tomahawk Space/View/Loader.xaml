<Page x:Class="Tomahawk_Space.View.Loader"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Tomahawk_Space.View"
      mc:Ignorable="d" 
      d:DesignHeight="390" d:DesignWidth="535"
      Title="Loader">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>

        <!--<Image Grid.Row="0" Name="ViewImage" Stretch="UniformToFill"/>-->
        <Border Name="ViewImage" Grid.Row="0" CornerRadius="5,5,0,0">
            <Border.Background>
                <ImageBrush Stretch="UniformToFill"/>
            </Border.Background>
        </Border>
        <Border Background="#191919" Grid.Row="1" CornerRadius="0,0,5,5">
            <DockPanel LastChildFill="False">
                <Button Name="LikeButton" DockPanel.Dock="Right" Width="40" Height="40" Margin="0,0,5,0" Style="{StaticResource RoundedButton}"
                        FontFamily="Segoe MDL2 Assets" FontSize="20" Content="&#xEB51;" Foreground="White"></Button>
            </DockPanel>
        </Border>
    </Grid>
</Page>
