                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </DockPanel>

            <Button Name="CloseButton" DockPanel.Dock="Right" Width="50" Style="{StaticResource NavButton}" 
                    FontFamily="Segoe MDL2 Assets" Content="&#xE8BB;" Foreground="White"
                    Click="CloseButton_Click"></Button>
            <Button Name="MinMaxButton" DockPanel.Dock="Right" Width="50" Style="{StaticResource NavButton}" 
                    FontFamily="Segoe MDL2 Assets" Content="&#xE922;" Foreground="White"
                    Click="MinMaxButton_Click"></Button>
            <Button Name="MinimizeButton" DockPanel.Dock="Right" Width="50" Style="{StaticResource NavButton}" 
                    FontFamily="Segoe MDL2 Assets" Content="&#xE921;" Foreground="White"
                    Click="MinimizeButton_Click"></Button>
        </DockPanel>

        <!-- основной контент -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"></ColumnDefinition>
                <ColumnDefinition Width="5"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <!-- зона навигации и управления -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                
                <!-- кнопки навигации -->
                <Border Background="#191919" Grid.Column="0" CornerRadius="5,0,0,5">
                    <DockPanel LastChildFill="False">
                        <Button Name="HomeButton" Click="HomeButton_Click" DockPanel.Dock="Top" Height="40" Width="40" 
                                Margin="0,5,0,0" Style="{StaticResource RoundedButton}"
                                FontFamily="Segoe MDL2 Assets" FontSize="20" Content="&#xE80F;" Foreground="White"></Button>
                        <Button Name="LikedButton" Click="LikedButton_Click" DockPanel.Dock="Top" Height="40" Width="40" 
                                Margin="0,5,0,0" Style="{StaticResource RoundedButton}"
                                FontFamily="Segoe MDL2 Assets" FontSize="20" Content="&#xEB51;" Foreground="White"></Button>
                        <Button Name="SettingsButton" Click="SettingsButton_Click" DockPanel.Dock="Bottom" Height="40" Width="40" 
                                Margin="0,0,0,5" Style="{StaticResource RoundedButton}" 
                                FontFamily="Segoe MDL2 Assets" FontSize="20" Content="&#xE713;" Foreground="White"></Button>
                    </DockPanel>
                </Border>

                <!-- кнопки управления -->
                <Border Grid.Column="1" Background="#222" CornerRadius="0,5,5,0">
                    <Frame Name="NavFrame" NavigationUIVisibility="Hidden" Source="Nav/Home.xaml">

                    </Frame>
                </Border>
            </Grid>
            
            <!-- зона просмотра -->
            <Border Grid.Column="2" Background="#222" CornerRadius="5">
                <Frame Name="ViewFrame" Source="View/Loader.xaml" NavigationUIVisibility="Hidden">

                </Frame>
            </Border>
        </Grid>
    </Grid>
</Window>
